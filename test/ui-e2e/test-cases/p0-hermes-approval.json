{
  "id": "p0-hermes-approval",
  "title": "Hermes 结构化审批请求可完成 approval_response 回传",
  "module": "会话",
  "objective": "验证 Hermes Gateway 下发结构化 approval_request 后，UI 渲染原生审批卡片，并在用户点击允许后向 Gateway 回传 approval_response=once。",
  "coverage": [
    "新建会话并发送触发审批的消息",
    "渲染 Hermes 结构化审批卡片",
    "点击原生审批按钮",
    "验证 Gateway 收到 approval_response 并返回最终确认文本"
  ],
  "tags": ["p0", "hermes", "approval", "ui"],
  "setup": {
    "serverMode": "openclaw",
    "accountId": "e2e_mock",
    "agentName": "E2E Mock Hermes",
    "httpPort": 18780,
    "upstreamPort": 18766,
    "mediaPort": 18781
  },
  "steps": [
    { "action": "launch_app" },
    { "action": "create_conversation", "name": "E2E Hermes Approval" },
    { "action": "send_message", "text": "测试 Hermes 结构化审批" },
    { "action": "wait_for_text", "text": "Hermes 请求执行命令" },
    { "action": "tap_text", "text": "允许", "exact": true },
    { "action": "wait_for_text", "text": "Hermes 已收到审批：once" }
  ],
  "mockGateway": {
    "interactions": [
      {
        "on": { "type": "chat", "contains": "测试 Hermes 结构化审批" },
        "replies": [
          {
            "type": "approval_request",
            "message_id": "hermes_approval_req_1",
            "command": "rm -rf /tmp/hermes-e2e",
            "description": "Hermes 请求执行命令",
            "pattern_keys": ["dangerous_delete"]
          }
        ]
      },
      {
        "on": { "type": "approval_response", "choice": "once" },
        "replies": [
          {
            "type": "agent_text_delta",
            "message_id": "agent_msg_hermes_approval_1",
            "delta": "Hermes 已收到审批：once"
          },
          {
            "type": "agent_text_done",
            "message_id": "agent_msg_hermes_approval_1",
            "fullText": "Hermes 已收到审批：once"
          }
        ]
      }
    ]
  },
  "assert": [
    { "uiTextVisible": "Hermes 已收到审批：once" }
  ]
}
