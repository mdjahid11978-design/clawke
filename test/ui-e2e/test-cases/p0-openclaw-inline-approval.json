{
  "id": "p0-openclaw-inline-approval",
  "title": "OpenClaw 内联审批卡片可回传普通 chat 确认",
  "module": "会话",
  "objective": "验证 OpenClaw markdown approval 代码块在 UI 中渲染为原生审批卡片，并在用户点击允许后以普通 chat 消息 y 回传。",
  "coverage": [
    "新建会话并发送触发内联审批的消息",
    "解析 OpenClaw markdown approval 代码块",
    "渲染原生内联审批卡片",
    "点击允许并验证 Gateway 收到普通 chat 确认"
  ],
  "tags": ["p0", "openclaw", "approval", "ui"],
  "setup": {
    "serverMode": "openclaw",
    "accountId": "e2e_mock",
    "agentName": "E2E Mock OpenClaw",
    "httpPort": 18780,
    "upstreamPort": 18766,
    "mediaPort": 18781
  },
  "steps": [
    { "action": "launch_app" },
    { "action": "create_conversation", "name": "E2E OpenClaw Approval" },
    { "action": "send_message", "text": "测试 OpenClaw 内联审批" },
    { "action": "wait_for_text", "text": "force kill processes" },
    { "action": "tap_text", "text": "允许", "exact": true },
    { "action": "wait_for_text", "text": "OpenClaw 已收到审批确认" }
  ],
  "mockGateway": {
    "interactions": [
      {
        "on": { "type": "chat", "contains": "测试 OpenClaw 内联审批" },
        "replies": [
          {
            "type": "agent_text_delta",
            "message_id": "agent_msg_openclaw_approval_1",
            "delta": "我分析了你的请求，需要执行以下操作。请确认：\n\n```approval\ncommand: pkill -9 -f \"Code Helper\"\ndescription: force kill processes\nrisk: high\n```\n\n确认后我会继续执行。"
          },
          {
            "type": "agent_text_done",
            "message_id": "agent_msg_openclaw_approval_1",
            "fullText": "我分析了你的请求，需要执行以下操作。请确认：\n\n```approval\ncommand: pkill -9 -f \"Code Helper\"\ndescription: force kill processes\nrisk: high\n```\n\n确认后我会继续执行。"
          }
        ]
      },
      {
        "on": { "type": "chat", "equals": "y" },
        "replies": [
          {
            "type": "agent_text_delta",
            "message_id": "agent_msg_openclaw_approval_2",
            "delta": "OpenClaw 已收到审批确认"
          },
          {
            "type": "agent_text_done",
            "message_id": "agent_msg_openclaw_approval_2",
            "fullText": "OpenClaw 已收到审批确认"
          }
        ]
      }
    ]
  },
  "assert": [
    { "uiTextVisible": "OpenClaw 已收到审批确认" }
  ]
}
