{
  "id": "p0-send-message",
  "title": "会话页可发送消息并渲染 Mock Gateway 流式回复",
  "module": "会话",
  "objective": "验证用户从会话页新建会话、发送文本消息后，UI 能显示用户消息、流式回复中间态和最终回复，并正确切换发送/停止按钮状态。",
  "coverage": [
    "新建会话",
    "发送文本消息",
    "显示流式回复中间态",
    "验证最终回复完整渲染",
    "验证发送/停止按钮状态切换"
  ],
  "tags": ["p0", "chat", "streaming", "ui"],
  "setup": {
    "serverMode": "openclaw",
    "accountId": "e2e_mock",
    "agentName": "E2E Mock Gateway",
    "httpPort": 18780,
    "upstreamPort": 18766,
    "mediaPort": 18781
  },
  "steps": [
    { "action": "launch_app" },
    { "action": "create_conversation", "name": "E2E P0 Send Message" },
    { "action": "send_message", "text": "你好 Clawke" },
    { "action": "wait_for_text", "text": "这是 Mock Gateway 的" },
    { "action": "wait_for_icon", "icon": "stop" },
    { "action": "wait_for_absent_text", "text": "这是 Mock Gateway 的稳定回复", "durationMs": 600 },
    { "action": "wait_for_text", "text": "这是 Mock Gateway 的稳定回复" },
    { "action": "wait_for_icon", "icon": "send" },
    { "action": "wait_for_absent_icon", "icon": "stop", "durationMs": 600 }
  ],
  "mockGateway": {
    "onUserMessage": {
      "contains": "你好 Clawke",
      "replies": [
        {
          "type": "agent_text_delta",
          "message_id": "agent_msg_p0_send_1",
          "delta": "这是 Mock Gateway 的",
          "delayMs": 80
        },
        {
          "type": "agent_text_delta",
          "message_id": "agent_msg_p0_send_1",
          "delta": "稳定回复",
          "delayMs": 2500
        },
        {
          "type": "agent_text_done",
          "message_id": "agent_msg_p0_send_1",
          "fullText": "这是 Mock Gateway 的稳定回复",
          "delayMs": 80
        }
      ]
    }
  },
  "assert": [
    { "uiTextVisible": "你好 Clawke" },
    { "uiTextVisible": "这是 Mock Gateway 的稳定回复" }
  ]
}
